# Dependencies
node_modules/

# Build output
dist/
dist-electron/

# Logs
logs/
*.log
npm-debug.log*

# Environment files (keep .env.example as template)
.env
.env.local
.env.development
.env.production
.env.staging
.env*.local

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code local settings
.claude/

# OS files
.DS_Store
Thumbs.db

# Electron
release/
dist-release/
electron/build-config.json
electron/.backup/
electron-compiled/

# Backup files
*.bak
*.bak*

# docs (whitelist go-migration)
docs/*
!docs/go-migration/

# Scripts (ignore all except whitelisted)
scripts/*
!scripts/run-electron.js
!scripts/compile-bytecode.js
!scripts/after-pack.js
!scripts/check-models-staleness.js
!scripts/update-models.js
!scripts/build-core.js
!scripts/recorder/

# Model staleness check flag (dev-only)
.models-stale

# Go build artifacts (air hot reload)
core/tmp/

# Compiled Go binaries for distribution
resources/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.Python

# playwright
.playwright-mcp/

# jsc
*.jsc