NODE_ENV=development

# Anthropic — used by Electron main process
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_SONNET_MODEL=anthropic/claude-sonnet-latest
ANTHROPIC_DEFAULT_OPUS_MODEL=anthropic/claude-opus-latest
ANTHROPIC_DEFAULT_HAIKU_MODEL=anthropic/claude-haiku-latest

# VITE_ prefix — exposed to the browser renderer via import.meta.env
VITE_ANTHROPIC_API_KEY=your-api-key-here
VITE_ANTHROPIC_BASE_URL=https://api.anthropic.com
VITE_ANTHROPIC_DEFAULT_SONNET_MODEL=anthropic/claude-sonnet-latest
VITE_ANTHROPIC_DEFAULT_OPUS_MODEL=anthropic/claude-opus-latest
VITE_ANTHROPIC_DEFAULT_HAIKU_MODEL=anthropic/claude-haiku-latest

# OpenRouter — alternative LLM provider
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api

# OpenAI-compatible provider
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://mlaas.virtuosgames.com

# System prompt — base identity for the AI assistant (leave empty for default)
SPARK_SYSTEM_PROMPT=

# Obsidian vault path (leave empty to pick on first launch)
OBSIDIAN_VAULT_PATH=

# MCP Servers (JSON — Claude Desktop format)
# Example: MCP_SERVERS={"my-server":{"command":"npx","args":["-y","@modelcontextprotocol/server-everything"],"env":{}}}
MCP_SERVERS={}

# HTTP Tools (JSON)
HTTP_TOOLS={}
